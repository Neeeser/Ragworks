# --- Required ---------------------------------------------------------------
# Secret used to sign auth tokens. Generate one with:
#   openssl rand -hex 32
JWT_SECRET_KEY=

# Password for the bundled Postgres instance (any strong value; used only
# inside the compose network).
POSTGRES_PASSWORD=

# --- Optional ---------------------------------------------------------------
# Image tag to run, e.g. v0.2.0. Defaults to latest.
#TRANSPARENTRAG_VERSION=latest

# Host port for the web UI. Defaults to 3000.
#FRONTEND_PORT=3000
